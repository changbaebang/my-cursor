# 로컬 전용 — cp .env.example .env && source .env (커밋 금지)
#
# 앱 만들기 · Scope · 테스트:
#   ~/.cursor/docs/automation/pr-review-slack-agent.md
#   § "Slack App 설정 런북 — PR 리뷰 리액션 (Phase 0.5)"
#
# 권장: User OAuth Token (본인 이름으로 리액션)
SLACK_USER_TOKEN=xoxp-your-user-token

# 또는 Bot Token (봇 이름으로 리액션, 채널 invite 필요할 수 있음)
# SLACK_USER_TOKEN=
# SLACK_BOT_TOKEN=xoxb-your-bot-token
